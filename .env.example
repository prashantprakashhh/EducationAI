# ============================================
# EduAI Environment Variables
# Copy this file: cp .env.example .env
# Then fill in ALL required values before deploying
# ============================================

# --- Database ---
DB_USERNAME=eduai
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- JWT Secret ---
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# --- Gemini AI API Key ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_YOUR_KEY_HERE

# --- CORS ---
# Set to your deployed frontend URL (no trailing slash)
CORS_ALLOWED_ORIGINS=https://clatone.co.in

# --- Admin Account ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@clatone.co.in
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# --- Frontend API URL ---
VITE_API_BASE_URL=https://clatone.co.in
